# JARVIS AI Assistant Configuration Example
# Copy this file to .env and fill in your actual values
# 
# Usage: cp jarvis/.env.example jarvis/.env
# Then edit jarvis/.env with your configuration

# ===========================================
# Models Directory
# ===========================================
# Base directory for all model files (Vosk, Piper, etc.)
# Default: models (relative to project root)
# MODELS_DIR=models

# ===========================================
# Speech-to-Text (Vosk) Configuration
# ===========================================
# Path to Vosk model directory
# Download from: https://alphacephei.com/vosk/models
# Example: wget https://alphacephei.com/vosk/models/vosk-model-small-en-us-0.15.zip
# Then unzip and set the path below
VOSK_MODEL_PATH=models/vosk/vosk-model-small-en-us-0.15

# ===========================================
# Large Language Model Configuration
# ===========================================
# LLM Provider: Choose between "ollama" (local) or "api" (remote API-based)
# Default: "ollama"
LLM_PROVIDER=ollama

# Model identifier (required for both providers)
# Examples for Ollama:
# - codegemma:7b-instruct-q5_K_M (good for coding)
# - llama3:8b (general purpose)
# - mistral:7b (balanced performance)
# - codellama:7b-instruct-q3_K_M (coding focused)
#
# Examples for API providers (OpenAI, Claude, OpenRouter, etc.):
# - gpt-4, gpt-3.5-turbo (OpenAI)
# - claude-3-opus-20240229 (Anthropic)
# - deepseek/deepseek-chat (OpenRouter)
# - Custom model identifier for your API
LLM_MODEL=qwen3:4b

# ===========================================
# LLM Connection Settings (all providers)
# ===========================================
# Base URL for LLM endpoint (default: http://localhost:11434)
# Examples:
# - Ollama local:   http://localhost:11434
# - OpenAI:         https://api.openai.com
# - Anthropic:      https://api.anthropic.com
# - OpenRouter:     https://openrouter.ai/api
# - Custom server:  https://your-llm-server.com
# NOTE: This is only for the chat LLM. Embeddings use EMBED_URL (see below).
# LLM_URL=http://localhost:11434

# API key for authentication (required for cloud/API providers)
# - Not needed for local Ollama
# - For Ollama cloud: get key at https://ollama.com/settings/keys
# - For other providers: get key from their website
# LLM_API_KEY=sk-...

# Optional: Custom headers as JSON string
# Most providers use Bearer token authentication via Authorization header (auto-set)
# LLM_API_HEADERS={"X-Custom-Header": "value"}

# Auto-pull missing Ollama models (true/false)
# - true: Automatically pull missing models without prompting
# - false: Prompt user to pull missing models (default)
# Set to "true" for non-interactive environments (scripts, CI/CD)
LLM_AUTO_PULL=false

# ===========================================
# Text-to-Speech (Piper) Configuration
# ===========================================
# Model files should be placed in models/piper/
# Download from: https://rhasspy.github.io/piper-samples/
TTS_MODEL_ONNX=en_US-amy-medium.onnx
TTS_MODEL_JSON=en_US-amy-medium.onnx.json

# ===========================================
# Voice Activation Configuration
# ===========================================
# Wake words to detect (comma-separated)
# Examples: "jarvis", "hey jarvis,okay jarvis", "alexa,hey alexa"
WAKE_WORDS=jarvis,hey jarvis,okay jarvis

# Voice activation sensitivity (0.0 to 1.0)
# Higher values = more sensitive (more false positives)
# Lower values = less sensitive (might miss wake words)
VOICE_ACTIVATION_SENSITIVITY=0.8

# ===========================================
# CLI Output Mode Configuration
# ===========================================
# Output mode for CLI: "text" or "voice"
# - text: Print responses as text
# - voice: Speak responses via TTS (default)
# Use "jarvis text" or "jarvis voice" to change mode
OUTPUT_MODE=voice

# ===========================================
# Conversation History Configuration
# ===========================================
# Reset conversation history after each response
# - true: Reset history after each response (default)
# - false: Maintain conversation context across interactions
# Useful for maintaining context in multi-turn conversations
RESET_HISTORY_AFTER_RESPONSE=true

# ===========================================
# Data Consent (Memory / Contextor)
# ===========================================
# Whether the user has consented to proactive memory storage
# - true: Remember what the user shares (name, preferences, etc.) without explicit "remember this"
# - false: Only remember when the user explicitly says "remember this" or "remember that"
DATA_CONSENT=true

# ===========================================
# Contextor (Memory) Subsystem
# ===========================================
# Enable or disable long-term memory
# - true: ROOT can route to contextor for remember/recall (default)
# - false: Memory disabled — ROOT only has respond and dispatch
CONTEXTOR_ENABLED=true

# ===========================================
# Context Window Sustainability
# ===========================================
# Max goals to include in LLM context (avoids overflow with many pending goals)
MAX_GOALS_IN_CONTEXT=20

# ===========================================
# Memory Pruning (Contextor)
# ===========================================
# Age-based: entries older than this many days are removed
MEMORY_RETENTION_DAYS=90

# FIFO: per-theme, keep at most this many entries (oldest dropped first)
MAX_ENTRIES_PER_THEME=500

# ===========================================
# Embedding / RAG Configuration
# ===========================================
# Ollama URL for embeddings — separate from LLM_URL because the LLM
# may live on a remote server while embeddings always run on local Ollama.
# Default: http://localhost:11434
# EMBED_URL=http://localhost:11434

# Embedding model (runs on local Ollama, ~270MB)
# Pull with: ollama pull nomic-embed-text
EMBED_MODEL=nomic-embed-text

# Enable RAG (Retrieval-Augmented Generation) — injects relevant
# memories into the LLM context for every user prompt
RAG_ENABLED=true

# Number of memories to retrieve per RAG query
RAG_TOP_K=5

# Minimum cosine similarity for RAG results (0.0–1.0)
RAG_MIN_SCORE=0.3

# ===========================================
# Semantic Tool Discovery
# ===========================================
# Master switch for vector-based tool search via dispatch/dmcp
ALLOW_EMBEDDING_SEARCH=true

# Bypass threshold — use vector search regardless of server count
# ENFORCE_EMBEDDING_SEARCH=false

# Minimum visible servers before vector search auto-enables
# EMBEDDING_SEARCH_THRESHOLD=100

# ===========================================
# Contextor Binary (Memory)
# ===========================================
# Path to the Rust contextor binary (default: "contextor" on PATH)
CONTEXTOR_BINARY=contextor

# ===========================================
# Tool-Level Confirmation
# ===========================================
# Confirmation mode for tool execution:
# - "allow_all": never ask (power users / trusted environments)
# - "smart":     ask only when tool has confirmation_required=true (default)
# - "ask_all":   ask for every tool call
CONFIRMATION_MODE=smart

# Suppress desktop notification for confirmation prompts
# (false = show notify-send popup; true = socket/CLI only)
# NOTIFICATION_SILENT=false

# Timeout (seconds) for user to respond to a confirmation prompt
CONFIRMATION_TIMEOUT=30

# ===========================================
# Data Directory
# ===========================================
# Base path for memory, goal archive, and default socket
# Default: ~/.jarvis (or /var/lib/jarvis when running as system service)
# JARVIS_DATA_DIR=~/.jarvis

# ===========================================
# Dual Input (voice + socket)
# ===========================================
# Unix socket path for "jarvis send" and app integration
# Default: JARVIS_DATA_DIR/input.sock (or /run/jarvis/input.sock for systemd)
# JARVIS_INPUT_SOCKET=~/.jarvis/input.sock

# Output socket for apps/widgets to receive responses (JSON lines)
# Default: JARVIS_DATA_DIR/output.sock
# JARVIS_OUTPUT_SOCKET=~/.jarvis/output.sock

# ===========================================
# Sudo Access Configuration
# ===========================================
# Allow jarvis user to have sudo access
# - true: Enable sudo access (jarvis user can run privileged commands)
# - false: Disable sudo access (more secure, default)
# Use "jarvis sudo enable" or "jarvis sudo disable" to change this setting
# Note: Changing this requires root privileges
JARVIS_SUDO_ENABLED=false

# ===========================================
# Dispatch Configuration
# ===========================================
# Path to the dispatch binary (default: "dispatch" on PATH)
DISPATCH_BINARY=dispatch

# Path to the dmcp binary (default: "dmcp" on PATH)
DMCP_BINARY=dmcp

# Timeout for dispatch operations in seconds
DISPATCH_TIMEOUT=60

# ===========================================
# Logging Configuration
# ===========================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# - DEBUG: Show all logs including detailed debugging information
# - INFO: Show informational messages and above (default)
# - WARNING: Show warnings and errors only
# - ERROR: Show errors only
# - CRITICAL: Show only critical errors
LOG_LEVEL=INFO

# Optional: Path to log file (leave empty for no file logging)
# Example: logs/jarvis.log
# If set, all logs will be written to this file in addition to console
LOG_FILE=

# Enable colored console output (true/false)
# Colorful logs make it easier to scan console output
LOG_COLORS=true

# ===========================================
# Optional Ollama Configuration
# ===========================================
# Uncomment these if you want to configure Ollama behavior
# OLLAMA_NO_GPU=1
# OLLAMA_NUM_THREADS=4

# ===========================================
# Optional System Configuration
# ===========================================
# Uncomment to enable debug logging
# DEBUG=1

# ===========================================
# Installation Notes
# ===========================================
# 1. Install Ollama: https://ollama.com/
# 2. Pull your LLM model: ollama pull qwen3:4b
# 3. Download Piper TTS model files to models/piper/
# 4. Download Vosk model: wget https://alphacephei.com/vosk/models/vosk-model-small-en-us-0.15.zip
# 5. Unzip Vosk model: unzip vosk-model-small-en-us-0.15.zip -d models/
# 6. Install dependencies: pip install vosk sounddevice
# 7. Ensure all dependencies are installed: pip install -r requirements.txt
# 8. Run JARVIS: python jarvis/main.py
